# ============================================================
# Ayisigimakademi - Üretim Ortamı Değişkenleri Şablonu
# Bu dosyayı .env.production olarak kopyalayıp gerçek değerleri doldurun.
# .env.production dosyası asla git'e eklenmez.
# ============================================================

# --- Moodle Genel ---
MOODLE_WWWROOT=https://portal.ayisigimakademi.com
MOODLE_DATAROOT=/home/HOSTINGER_USER/moodledata

# --- Veritabanı (Hostinger hPanel > Databases'den alın) ---
MOODLE_DB_TYPE=mysqli
MOODLE_DB_HOST=localhost
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=u123456789_moodle
MOODLE_DB_USER=u123456789_moodleuser
MOODLE_DB_PASS=change_this_strong_password
MOODLE_DB_PREFIX=mdl_

# --- Moodle Admin ---
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=change_this_strong_admin_password
MOODLE_ADMIN_EMAIL=admin@ayisigimakademi.com

# --- Hostinger FTP (deploy scripti için) ---
FTP_HOST=ftp.ayisigimakademi.com
FTP_USER=u123456789
FTP_PASS=change_this_ftp_password
FTP_REMOTE_PATH=/public_html/portal

# --- SMTP (Hostinger Email veya harici SMTP) ---
SMTP_HOST=mail.ayisigimakademi.com
SMTP_PORT=587
SMTP_USER=noreply@ayisigimakademi.com
SMTP_PASS=change_this_smtp_password
SMTP_SECURE=tls
