# ============================================================
# Ayisigimakademi - Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp gerçek değerlerle doldurun.
# .env dosyası asla git'e eklenmez.
# ============================================================

# --- Moodle Genel ---
MOODLE_WWWROOT=http://portal.localhost
MOODLE_DATAROOT=/var/moodledata

# --- Veritabanı ---
MOODLE_DB_TYPE=mysqli
MOODLE_DB_HOST=db
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASS=change_this_password
MOODLE_DB_PREFIX=mdl_

# --- MySQL root (Docker için) ---
MYSQL_ROOT_PASSWORD=change_this_root_password

# --- Moodle Admin ---
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=change_this_admin_password
MOODLE_ADMIN_EMAIL=admin@ayisigimakademi.com

# --- Site Bilgileri ---
MOODLE_SITE_FULLNAME=Ayisigimakademi Portal
MOODLE_SITE_SHORTNAME=AYK-Portal

# --- phpMyAdmin (sadece yerel geliştirme) ---
PMA_PORT=8080

# --- Moodle SMTP (E-posta bildirimleri) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@ayisigimakademi.com
SMTP_PASS=change_this_smtp_password
SMTP_SECURE=tls
